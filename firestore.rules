rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Funciones de Ayuda ────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'UserRole.admin';
    }

    function isEmployee() {
      return isAuthenticated() && (
        getUserData().role == 'UserRole.admin' ||
        getUserData().role == 'UserRole.employee'
      );
    }

    // ─── Colección: users ─────────────────────────────────────────────
    match /users/{userId} {
      // Cualquier usuario autenticado puede leer su propio perfil
      allow read: if isAuthenticated() && isOwner(userId);
      // Solo admins pueden leer todos los perfiles
      allow list: if isAdmin();
      // Un usuario solo puede escribir su propio perfil (al registrarse)
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // ─── Colección: products ──────────────────────────────────────────
    match /products/{productId} {
      // Cualquier usuario autenticado puede ver productos
      allow read: if isAuthenticated();
      // Solo admins/empleados pueden crear, editar o borrar productos
      allow create, update, delete: if isEmployee();
    }

    // ─── Colección: services ──────────────────────────────────────────
    match /services/{serviceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isEmployee();
    }

    // ─── Colección: orders ────────────────────────────────────────────
    match /orders/{orderId} {
      // Un cliente puede leer solo sus propios pedidos
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isEmployee()
      );
      // Un cliente autenticado puede crear pedidos propios
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      // Solo empleados/admins pueden actualizar el estado del pedido
      allow update: if isEmployee();
      allow delete: if isAdmin();

      // Subcolección items del pedido
      match /items/{itemId} {
        allow read: if isAuthenticated();
        allow write: if isEmployee();
      }
    }

    // ─── Colección: employees ─────────────────────────────────────────
    match /employees/{employeeId} {
      allow read: if isEmployee();
      allow create, update, delete: if isAdmin();
    }

    // ─── Colección: occasions ─────────────────────────────────────────
    match /occasions/{occasionId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isEmployee();
    }

    // ─── Colección: payments ──────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isEmployee()
      );
      allow create: if isAuthenticated();
      allow update, delete: if isEmployee();
    }

  }
}
