rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Imágenes de Productos ────────────────────────────────────────
    match /products/{productId}/{allImages=**} {
      // Cualquier usuario autenticado puede leer imágenes de productos
      allow read: if request.auth != null;
      // Solo usuarios autenticados pueden subir imágenes (validar rol en la app)
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024 // Máx 5MB
        && request.resource.contentType.matches('image/.*');
    }

    // ─── Comprobantes de Pago ─────────────────────────────────────────
    match /payments/{paymentId}/{allFiles=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024; // Máx 10MB
    }

    // ─── Fotos de Perfil ──────────────────────────────────────────────
    match /users/{userId}/avatar/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024 // Máx 2MB
        && request.resource.contentType.matches('image/.*');
    }

  }
}
